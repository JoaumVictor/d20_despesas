# Supabase
URL=https://<seu-projeto>.supabase.co
KEY=<anon-public-key>

# Conexão direta ao Postgres (uso em migrations, não vai para o app)
DATABASE_PASSWORD=<senha-do-banco>
DIRECT_CONNECTION=postgresql://postgres:<senha>@db.<projeto>.supabase.co:5432/postgres

# Google OAuth (Web client do Google Cloud Console)
GOOGLE_WEB_CLIENT_ID=<id>.apps.googleusercontent.com
